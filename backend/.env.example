# Email + Celery local settings template.
# Copy to backend/.env and set real values in your shell/session.

# --- Django core ---
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_SECRET_KEY=change-me
# Dev-only endpoint toggle for deleting the currently logged-in account.
DEV_ACCOUNT_DELETE_ENABLED=1

# --- Celery ---
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=django-db
# Set to 1 to execute Celery tasks inline (no Redis/worker required).
CELERY_TASK_ALWAYS_EAGER=0
CELERY_TASK_EAGER_PROPAGATES=1

# --- Email ---
# Options: console | postmark | sendgrid | smtp
EMAIL_PROVIDER=console
DEFAULT_FROM_EMAIL=Agger Grand <no-reply@aggergrand.local>
EMAIL_TIMEOUT=10

# Postmark preset:
# EMAIL_PROVIDER=postmark
# POSTMARK_SERVER_TOKEN=replace_me
# EMAIL_HOST=smtp.postmarkapp.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=1

# SendGrid preset:
# EMAIL_PROVIDER=sendgrid
# SENDGRID_API_KEY=replace_me
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=1

# Generic SMTP preset:
# EMAIL_PROVIDER=smtp
# EMAIL_HOST=smtp.your-provider.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your_user
# EMAIL_HOST_PASSWORD=your_pass
# EMAIL_USE_TLS=1
